#!/usr/bin/env bash
set -euo pipefail

FS_PREFIX="${FS_PREFIX:-/usr/local/freeswitch}"
export LD_LIBRARY_PATH="${FS_PREFIX}/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export PATH="${FS_PREFIX}/bin:${PATH}"
export FSWTCH_AI_ALLOW_MOCK=1

mkdir -p \
  "${FS_PREFIX}/db" \
  "${FS_PREFIX}/log" \
  "${FS_PREFIX}/recordings" \
  "${FS_PREFIX}/run" \
  "${FS_PREFIX}/storage"

dump_logs() {
  local log_file

  for log_file in \
    "${FS_PREFIX}/log/freeswitch-console.log" \
    "${FS_PREFIX}/log/freeswitch.log" \
    "${FS_PREFIX}/log/freeswitch.xml.fsxml"; do
    if [[ -s "${log_file}" ]]; then
      printf '\n===== %s =====\n' "${log_file}" >&2
      tail -n 200 "${log_file}" >&2 || true
    fi
  done
}

stop_freeswitch() {
  fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x shutdown >/dev/null 2>&1 || true
  freeswitch -stop >/dev/null 2>&1 || true
  pkill freeswitch >/dev/null 2>&1 || true
}
trap stop_freeswitch EXIT
trap 'status=$?; dump_logs; exit "${status}"' ERR

freeswitch \
  -nonat \
  -ncwait \
  -base "${FS_PREFIX}" \
  -conf "${FS_PREFIX}/conf" \
  -log "${FS_PREFIX}/log" \
  -db "${FS_PREFIX}/db" \
  -run "${FS_PREFIX}/run" \
  >"${FS_PREFIX}/log/freeswitch-console.log" \
  2>&1

for _ in $(seq 1 30); do
  if fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x status >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x status >/dev/null

assert_api() {
  local command="$1"
  local expected="$2"
  local output

  output="$(fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x "${command}" | tr -d '\r')"
  if [[ "${output}" != *"${expected}"* ]]; then
    printf 'API check failed\ncommand: %s\nexpected: %s\nactual:\n%s\n' \
      "${command}" "${expected}" "${output}" >&2
    exit 1
  fi

  printf 'ok: %s -> %s\n' "${command}" "${expected}"
}

assert_api "rust_hello" "hello from Rust"
assert_api "rust_ping" "pong"
assert_api "rust_echo fswtch works" "fswtch works"
assert_api "rust_upper fswtch" "FSWTCH"
assert_api "rust_job_submit payload" "job queued id="
assert_api "rust_playback_control_info" "application rust_playback_control registered"
assert_api 'rust_cdr_enrich {"uuid":"call-1","account":"vip-100","destination":"+15551234567","duration":13}' '"account_tier":"gold"'
assert_api "rust_chatbot_bridge_stats" "chatbot_bridge_registered=true"
assert_api "rust_config_xml_show" "greeting=hello from fswtch XML"
assert_api "rust_endpoint_skeleton_info" "endpoint rust_endpoint_skeleton registered"
assert_api 'rust_event_sink_emit fswtch::smoke {"call_uuid":"call-1","score":99}' "event fired count="
assert_api 'rust_webhook_post http://127.0.0.1:9/smoke {"event":"smoke"}' "webhook queued"
assert_api "rust_table" "language,rust"
assert_api "rust_words one two three" "3 words"
assert_api "rust_lifecycle_stats" "loads=1"
assert_api "rust_local_ai_status" "asr_backend=mock tts_backend=mock nlp_backend=mock"
assert_api "rust_local_tts hello" "backend=mock sample_rate=16000"
assert_api "rust_local_nlp_sync hello" "mock nlp response: hello"
assert_api "rust_media_bug_meter_stats" "attached=0"
assert_api "rust_metrics_hit smoke" "metric=smoke count=1"
assert_api "rust_metrics_show" 'fswtch_example_events_total{name="smoke"} 1'
assert_api "rust_rate_limit smoke-key 2 60" "allowed=true remaining=1"
assert_api "rust_check_registration alice@example.com https://server/check" "registration check queued"
assert_api "rust_vad_start call-123 ws://127.0.0.1:9" "remote VAD worker started"
assert_api "rust_vad_esl_start" "usage: rust_vad_esl_start <uuid>"

printf 'all fswtch example module checks passed\n'

#!/usr/bin/env bash
set -euo pipefail

FS_PREFIX="${FS_PREFIX:-/usr/local/freeswitch}"
export LD_LIBRARY_PATH="${FS_PREFIX}/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export PATH="${FS_PREFIX}/bin:${PATH}"

mkdir -p \
  "${FS_PREFIX}/db" \
  "${FS_PREFIX}/log" \
  "${FS_PREFIX}/recordings" \
  "${FS_PREFIX}/run" \
  "${FS_PREFIX}/storage"

dump_logs() {
  local log_file

  for log_file in \
    "${FS_PREFIX}/log/freeswitch-console.log" \
    "${FS_PREFIX}/log/freeswitch.log" \
    "${FS_PREFIX}/log/freeswitch.xml.fsxml"; do
    if [[ -s "${log_file}" ]]; then
      printf '\n===== %s =====\n' "${log_file}" >&2
      tail -n 200 "${log_file}" >&2 || true
    fi
  done
}

stop_freeswitch() {
  fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x shutdown >/dev/null 2>&1 || true
  freeswitch -stop >/dev/null 2>&1 || true
  pkill freeswitch >/dev/null 2>&1 || true
}
trap stop_freeswitch EXIT
trap 'status=$?; dump_logs; exit "${status}"' ERR

freeswitch \
  -nonat \
  -ncwait \
  -base "${FS_PREFIX}" \
  -conf "${FS_PREFIX}/conf" \
  -log "${FS_PREFIX}/log" \
  -db "${FS_PREFIX}/db" \
  -run "${FS_PREFIX}/run" \
  >"${FS_PREFIX}/log/freeswitch-console.log" \
  2>&1

for _ in $(seq 1 30); do
  if fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x status >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x status >/dev/null

assert_api() {
  local command="$1"
  local expected="$2"
  local output

  output="$(fs_cli -H 127.0.0.1 -P 8021 -p ClueCon -x "${command}" | tr -d '\r')"
  if [[ "${output}" != *"${expected}"* ]]; then
    printf 'API check failed\ncommand: %s\nexpected: %s\nactual:\n%s\n' \
      "${command}" "${expected}" "${output}" >&2
    exit 1
  fi

  printf 'ok: %s -> %s\n' "${command}" "${expected}"
}

assert_api "rust_hello" "hello from Rust"
assert_api "rust_ping" "pong"
assert_api "rust_echo fswtch works" "fswtch works"
assert_api "rust_upper fswtch" "FSWTCH"
assert_api "rust_table" "language,rust"
assert_api "rust_words one two three" "3 words"
assert_api "rust_lifecycle_stats" "loads=1"
assert_api "rust_check_registration alice@example.com https://server/check" "registration check queued"
assert_api "rust_vad_start call-123 ws://127.0.0.1:9" "remote VAD worker started"

printf 'all fswtch example module checks passed\n'
